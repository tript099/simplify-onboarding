# Simplify Onboarding Service — environment template.
# Copy to `.env` and fill in the secrets. The service is STANDALONE: it depends only on
# Zitadel (the shared IdP) + its OWN Redis + its OWN Postgres. MailForge (email) and the
# meeting scheduler are shared infrastructure reached over HTTP with a key/passcode.

APP_ENV=development
PORT=8090

# ── Identity (Zitadel — shared IdP) ─────────────────────────────────
IDENTITY_PROVIDER=zitadel
ZITADEL_ISSUER=https://auth.simplifyaipro.com
ZITADEL_INTERNAL_URL=https://auth.simplifyaipro.com
ZITADEL_CLIENT_ID=
ZITADEL_SERVICE_PAT=
ZITADEL_ORG_ID=
# Federated SSO — the Zitadel IdP ids for Google / Microsoft
IDP_GOOGLE_ID=
IDP_MICROSOFT_ID=

# ── Own session store (Redis) + database (Postgres) ─────────────────
REDIS_URL=redis://onboarding-redis:6379
REDIS_DB=0
ONBOARDING_DATABASE_URL=postgres://onboarding:onboarding@onboarding-db:5432/onboarding?sslmode=disable
SESSION_PERSIST=true

# ── Cookies / CORS / frontend ───────────────────────────────────────
COOKIE_SECURE=false
# COOKIE_DOMAIN=.simplifyaipro.com   # prod: share cookie across product subdomains
FRONTEND_URL=http://localhost:3100
CORS_ALLOWED_ORIGINS=http://localhost:3100,http://localhost:3000
DEBUG_RETURN_CODE=false
SIMPLIFYCORE_STUB=true

# Guards the internal POST /onb/demo/{id}/schedule endpoint (leave empty in dev).
INTERNAL_JWT_SECRET=

# ── Demo account ("Try it now") ─────────────────────────────────────
DEMO_ENABLED=true
DEMO_EMAIL=demo@simplifyai.id
DEMO_PASSWORD=
DEMO_FIRST_NAME=Simplify
DEMO_LAST_NAME=Demo

# ── Email (MailForge — shared service, dedicated onboarding project key) ─
MAILFORGE_URL=http://host.docker.internal:8099
MAILFORGE_API_KEY=               # mf_proj_… send key for the "Simplify Onboarding" project
MAILFORGE_FROM_NAME=Simplify
MAILFORGE_FROM_EMAIL=no-reply@simplifyai.id
MAILFORGE_REPLY_TO=sales@simplifyai.id
DEMO_RECIPIENTS_FILE=/app/config/demo-recipients.json

# ── Meeting scheduler (shared service) ──────────────────────────────
# /schedule_teams works today; /schedule_google currently 500s on the scheduler.
SCHEDULER_URL=https://scheduler.simplifyaipro.com
SCHEDULER_PATH=/schedule_google
SCHEDULER_PASSCODE=
SCHEDULER_DURATION_MIN=30

# MailForge template ids (provisioned via scripts/provision-email-templates.py)
MAILFORGE_TEMPLATE_CONFIRMATION=
MAILFORGE_TEMPLATE_TEAM_NOTIFY=
MAILFORGE_TEMPLATE_INVITE=
