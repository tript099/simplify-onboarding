# ── core ───────────────────────────────────────────────────────────
PORT=8090
APP_ENV=development
FRONTEND_URL=http://localhost:3100
GATEWAY_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3100

# ── redis (sessions / visitor state) ───────────────────────────────
# For silent SSO, point REDIS_URL at the SHARED platform Redis that products read
# (DocFlow uses redis://redis:6379 DB1). See SSO_INTEGRATION.md.
REDIS_URL=redis://localhost:6379
REDIS_DB=1
SESSION_TTL=30m
SESSION_ABS_MAX=8h
# Central SSO session never expires on its own — only logout removes it.
SESSION_PERSIST=true
COOKIE_SECURE=false
# Share the cookie across product subdomains in production:
# COOKIE_DOMAIN=.simplifyaipro.com

# ── shared platform DB (silent SSO) ────────────────────────────────
# When set, sessions are written in DocFlow's schema (internal user id + tenant +
# role) so products reading the shared Redis pick them up directly. Leave unset for
# a portal-only deployment.
# DATABASE_URL=postgresql://docflow:***@pgbouncer:6543/docflow?sslmode=disable

# ── identity backend ───────────────────────────────────────────────
# dev = self-contained (redis + bcrypt); zitadel = platform IdP (scaffold)
IDENTITY_PROVIDER=dev
# ZITADEL_ISSUER=
# ZITADEL_INTERNAL_URL=
# ZITADEL_CLIENT_ID=
# ZITADEL_SERVICE_PAT=
# ZITADEL_ORG_ID=

# ── otp ────────────────────────────────────────────────────────────
OTP_TTL=10m
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN=30s
# accept 123456 in non-prod for prototyping
OTP_DEV_BYPASS=true
OTP_EMAIL_FROM=no-reply@simplify.local
# MAILFORGE_BASE_URL=   # unset → codes printed to logs (dev)
# MAILFORGE_API_KEY=
OTP_SMS_PROVIDER=log

# ── entitlements (SimplifyCore) ────────────────────────────────────
SIMPLIFYCORE_STUB=true
# SIMPLIFYCORE_BASE_URL=
# SIMPLIFYCORE_TOKEN=

# ── service-to-service ─────────────────────────────────────────────
# INTERNAL_JWT_SECRET=
# PRODUCT_REGISTRY_FILE=/etc/simplify/products.json
