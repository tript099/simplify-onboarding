# Use the mock API (default in dev) — UI runs standalone without the backend.
# Set to "false" once simplify-onboarding-service is reachable behind the gateway.
VITE_USE_MOCK=true

# Same-origin gateway prefix for /auth/* and /onb/* (Part A/B of the backend plan).
VITE_AUTH_BASE=/auth

# Show the prototype OTP hint (any-6-digits / 123456). Staging only.
VITE_OTP_DEV_HINT=false

# Default country for the phone field.
VITE_DEFAULT_COUNTRY=ID
